# ---- Supabase ----
# Settings → API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # server-side only (Vercel env + local api)
SUPABASE_ANON_KEY=                    # used by the web admin UI

# Default org slug when legacy webhook URLs omit ?org= / :orgSlug
DEFAULT_ORG_SLUG=dooly

# ---- Airtable ----
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ---- Ingestion API ----
PORT=8787
# Shared secret for Typeform / Calendly / Whop (legacy / dooly fallback).
# Generate with:  openssl rand -hex 32
WEBHOOK_SECRET=change-me

# Legacy global vendor tokens (used for DEFAULT_ORG_SLUG / dooly if ORG_* not set)
TYPEFORM_API_KEY=          # tfp_...
CALENDLY_API_KEY=          # PAT — needs webhooks:write to auto-register
TYPEFORM_FORM_IDS=AbXAZxlr # comma-separated form ids
ORG_SLUG=dooly             # used by npm run register-webhooks

# ---- Per-org secrets (preferred for additional clients) ----
# After creating an org with slug "acme", set these in Vercel + local .env:
#   ORG_ACME_WEBHOOK_SECRET=
#   ORG_ACME_CALENDLY_PAT=          # only if bookings_provider=calendly
#   ORG_ACME_TYPEFORM_API_KEY=      # only if forms_provider=typeform
#   ORG_ACME_TYPEFORM_FORM_IDS=
#   ORG_ACME_ICLOSED_API_KEY=       # only if forms/bookings_provider=iclosed
#   ORG_ACME_FANBASIS_API_KEY=      # only if payments_provider=fanbasis
# Slug hyphens become underscores: "acme-co" → ORG_ACME_CO_WEBHOOK_SECRET
#
# Providers are multi-select in Admin → org
# (forms: typeform/iclosed, bookings: calendly/iclosed, payments: whop/fanbasis).
# iClosed uses: POST /api/webhooks/<slug>/iclosed?secret=…
# Fanbasis uses: POST /api/webhooks/<slug>/payments?source=fanbasis&secret=…
#
# Example — Eman (slug emanfba):
# ORG_EMANFBA_WEBHOOK_SECRET=
# ORG_EMANFBA_ICLOSED_API_KEY=

# Same-person matching rules: server/src/config/identity-match.json
# After migration 0006: npm run scan-matches  (backfill flags)

# After Vercel deploy, set this and run: WEBHOOK_BASE_URL=… ORG_SLUG=… npm run register-webhooks
WEBHOOK_BASE_URL=https://opsdashboarddooly.vercel.app

# ---- Vercel (Project → Settings → Environment Variables) ----
# Required for /api/* serverless function:
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, WEBHOOK_SECRET (and/or ORG_* secrets)
# Required for the static web build (VITE_* are baked in at build time):
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY

# Optional vendor-native signing secrets
# TYPEFORM_WEBHOOK_SECRET=
# CALENDLY_WEBHOOK_SIGNING_KEY=
# WHOP_WEBHOOK_SECRET=

# ---- Web (Vite requires the VITE_ prefix; mirror the values above) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=
# Optional: leave empty in local dev (Vite proxies /api → :8787)
# VITE_API_BASE=
