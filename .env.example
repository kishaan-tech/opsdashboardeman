# ---- Supabase ----
# Settings → API in your Supabase dashboard
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # server-side only: api/ and tools/ use this
SUPABASE_ANON_KEY=                    # used by the web admin UI

# ---- Airtable ----
# Personal access token: https://airtable.com/create/tokens
# Scopes needed: schema.bases:read, data.records:read
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ---- Ingestion API ----
PORT=8787
# Shared secret: senders must include it as an `x-webhook-secret` header
WEBHOOK_SECRET=change-me

# ---- Web (Vite requires the VITE_ prefix; mirror the values above) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=
