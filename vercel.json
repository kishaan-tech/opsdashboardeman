{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/webhooks/:path*", "destination": "/api/webhooks/:path*" },
    { "source": "/admin/:path*", "destination": "/api/admin/:path*" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "functions": {
    "api/health.js": {
      "maxDuration": 10,
      "memory": 256
    },
    "api/webhooks/forms.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "server/**"
    },
    "api/webhooks/bookings.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "server/**"
    },
    "api/webhooks/payments.js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "server/**"
    },
    "api/[...path].js": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "server/**"
    }
  }
}
